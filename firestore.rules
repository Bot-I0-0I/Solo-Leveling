rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // This security rules file assumes the following data structures:
    //
    // Collection: userStats
    // Document ID: {uid}
    // Fields:
    //   - STR: number (required)
    //   - VIT: number (required)
    //   - AGI: number (required)
    //   - INT: number (required)
    //   - SEN: number (required)
    //   - credits: number (required)
    //   - xp: number (required)
    //   - penaltyActive: boolean (required)
    //   - lastResetDate: string (required)
    //   - name: string (optional)
    //   - avatar: string (optional)
    //   - height: number (optional)
    //   - age: number (optional)
    //   - gender: string (optional)
    //   - notes: string (optional)
    //   - fitnessGoal: string (optional)
    //   - activityLevel: string (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: quests
    // Document ID: {questId}
    // Fields:
    //   - title: string (required)
    //   - attribute: string (required)
    //   - targetValue: number (required)
    //   - currentValue: number (required)
    //   - type: string (required)
    //   - completed: boolean (required)
    //   - date: string (required)
    //   - baseReward: number (required)
    //   - uid: string (required, immutable)
    //
    // Collection: dungeons
    // Document ID: {dungeonId}
    // Fields:
    //   - title: string (required)
    //   - totalHealth: number (required)
    //   - currentHealth: number (required)
    //   - status: string (required)
    //   - shadowExtracted: boolean (required)
    //   - rewardCredits: number (optional)
    //   - rewardXp: number (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: inventory
    // Document ID: {itemId}
    // Fields:
    //   - name: string (required)
    //   - type: string (required)
    //   - attributeBoosts: map (required)
    //   - equipped: boolean (required)
    //   - uid: string (required, immutable)
    //
    // Collection: shopItems
    // Document ID: {itemId}
    // Fields:
    //   - name: string (required)
    //   - cost: number (required)
    //   - attributeBoosts: map (required)
    //   - purchased: boolean (required)
    //   - uid: string (required, immutable)
    //
    // Collection: vesselLogs
    // Document ID: {logId}
    // Fields:
    //   - date: string (required)
    //   - weight: number (optional)
    //   - bodyFat: number (optional)
    //   - sleepHours: number (optional)
    //   - stressLevel: number (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: weeklyReviews
    // Document ID: {reviewId}
    // Fields:
    //   - weekStartDate: string (required)
    //   - accomplishments: string (required)
    //   - challenges: string (required)
    //   - intentions: string (required)
    //   - status: string (required)
    //   - uid: string (required, immutable)
    //
    // Collection: tasks
    // Document ID: {taskId}
    // Fields:
    //   - title: string (required)
    //   - date: string (required)
    //   - time: string (required)
    //   - completed: boolean (required)
    //   - priority: string (required)
    //   - recurrence: string (optional)
    //   - xpReward: number (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: ledger
    // Document ID: {entryId}
    // Fields:
    //   - date: string (required)
    //   - amount: number (required)
    //   - type: string (required)
    //   - description: string (required)
    //   - category: string (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: nutritionLogs
    // Document ID: {logId}
    // Fields:
    //   - date: string (required)
    //   - type: string (required)
    //   - name: string (required)
    //   - calories: number (required)
    //   - protein: number (optional)
    //   - carbs: number (optional)
    //   - fat: number (optional)
    //   - duration: number (optional)
    //   - muscleGroup: string (optional)
    //   - amount: number (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: tacticalLogs
    // Document ID: {logId}
    // Fields:
    //   - date: string (required)
    //   - game: string (required)
    //   - focusArea: string (required)
    //   - result: string (required)
    //   - kills: number (required)
    //   - deaths: number (required)
    //   - notes: string (optional)
    //   - uid: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isValidOptionalNumber(field) {
      return !(field in request.resource.data) || request.resource.data[field] is number;
    }

    function isFriendRequestAccepted(uid1, uid2) {
      return (exists(/databases/$(database)/documents/friendRequests/$(uid1 + '_' + uid2)) && get(/databases/$(database)/documents/friendRequests/$(uid1 + '_' + uid2)).data.status == 'accepted') ||
             (exists(/databases/$(database)/documents/friendRequests/$(uid2 + '_' + uid1)) && get(/databases/$(database)/documents/friendRequests/$(uid2 + '_' + uid1)).data.status == 'accepted');
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserStats(data) {
      let requiredFields = ['STR', 'VIT', 'AGI', 'INT', 'SEN', 'credits', 'xp', 'penaltyActive', 'lastResetDate', 'uid'];
      let optionalFields = ['name', 'avatar', 'height', 'age', 'gender', 'notes', 'fitnessGoal', 'activityLevel', 'friends'];
      let allFields = requiredFields.concat(optionalFields);

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             data.STR is number && data.STR >= 0 &&
             data.VIT is number && data.VIT >= 0 &&
             data.AGI is number && data.AGI >= 0 &&
             data.INT is number && data.INT >= 0 &&
             data.SEN is number && data.SEN >= 0 &&
             data.credits is number && data.credits >= 0 &&
             data.xp is number && data.xp >= 0 &&
             data.penaltyActive is bool &&
             validStringLength('lastResetDate', 10, 10) &&
             data.uid == request.auth.uid &&
             isValidOptionalString('name', 0, 100) &&
             isValidOptionalString('avatar', 0, 500) &&
             isValidOptionalNumber('height') &&
             isValidOptionalNumber('age') &&
             (!( 'gender' in data ) || data.gender in ['male', 'female', 'other']) &&
             isValidOptionalString('notes', 0, 5000) &&
             (!( 'fitnessGoal' in data ) || data.fitnessGoal in ['lose', 'maintain', 'build']) &&
             (!( 'activityLevel' in data ) || data.activityLevel in ['sedentary', 'light', 'moderate', 'active', 'very_active']) &&
             (!( 'friends' in data ) || data.friends is list);
    }

    function isValidPublicProfile(data) {
      let requiredFields = ['uid', 'email', 'name', 'level', 'rank'];
      let optionalFields = ['avatar'];
      let allFields = requiredFields.concat(optionalFields);

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             data.uid == request.auth.uid &&
             validStringLength('email', 3, 100) &&
             validStringLength('name', 1, 100) &&
             data.level is number && data.level >= 1 &&
             validStringLength('rank', 1, 50) &&
             isValidOptionalString('avatar', 0, 500);
    }

    function isValidFriendRequest(data) {
      let requiredFields = ['fromUid', 'toUid', 'fromEmail', 'toEmail', 'fromName', 'status', 'createdAt'];
      let allFields = requiredFields;

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('fromUid', 1, 100) &&
             validStringLength('toUid', 1, 100) &&
             validStringLength('fromEmail', 3, 100) &&
             validStringLength('toEmail', 3, 100) &&
             validStringLength('fromName', 1, 100) &&
             data.status in ['pending', 'accepted', 'rejected'] &&
             validStringLength('createdAt', 10, 30);
    }

    function isValidQuest(data) {
      let requiredFields = ['title', 'attribute', 'targetValue', 'currentValue', 'type', 'completed', 'date', 'baseReward', 'uid'];
      let allFields = requiredFields;

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('title', 1, 200) &&
             data.attribute in ['STR', 'VIT', 'AGI', 'INT', 'SEN'] &&
             data.targetValue is number && data.targetValue >= 0 &&
             data.currentValue is number && data.currentValue >= 0 &&
             data.type in ['daily', 'penalty'] &&
             data.completed is bool &&
             validStringLength('date', 10, 10) &&
             data.baseReward is number && data.baseReward >= 0 &&
             data.uid == request.auth.uid;
    }

    function isValidDungeon(data) {
      let requiredFields = ['title', 'totalHealth', 'currentHealth', 'status', 'shadowExtracted', 'uid'];
      let optionalFields = ['rewardCredits', 'rewardXp'];
      let allFields = requiredFields.concat(optionalFields);

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('title', 1, 200) &&
             data.totalHealth is number && data.totalHealth > 0 &&
             data.currentHealth is number && data.currentHealth >= 0 &&
             data.status in ['active', 'cleared'] &&
             data.shadowExtracted is bool &&
             isValidOptionalNumber('rewardCredits') &&
             isValidOptionalNumber('rewardXp') &&
             data.uid == request.auth.uid;
    }

    function isValidInventoryItem(data) {
      let requiredFields = ['name', 'type', 'attributeBoosts', 'equipped', 'uid'];
      let allFields = requiredFields;

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('name', 1, 200) &&
             data.type in ['item', 'shadow'] &&
             data.attributeBoosts is map &&
             data.equipped is bool &&
             data.uid == request.auth.uid;
    }

    function isValidShopItem(data) {
      let requiredFields = ['name', 'cost', 'attributeBoosts', 'purchased', 'uid'];
      let allFields = requiredFields;

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('name', 1, 200) &&
             data.cost is number && data.cost >= 0 &&
             data.attributeBoosts is map &&
             data.purchased is bool &&
             data.uid == request.auth.uid;
    }

    function isValidVesselLog(data) {
      let requiredFields = ['date', 'uid'];
      let optionalFields = ['weight', 'bodyFat', 'sleepHours', 'stressLevel'];
      let allFields = requiredFields.concat(optionalFields);

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('date', 10, 10) &&
             isValidOptionalNumber('weight') &&
             isValidOptionalNumber('bodyFat') &&
             isValidOptionalNumber('sleepHours') &&
             (!( 'stressLevel' in data ) || data.stressLevel in [1, 2, 3, 4, 5]) &&
             data.uid == request.auth.uid;
    }

    function isValidWeeklyReview(data) {
      let requiredFields = ['weekStartDate', 'accomplishments', 'challenges', 'intentions', 'status', 'uid'];
      let allFields = requiredFields;

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('weekStartDate', 10, 10) &&
             validStringLength('accomplishments', 0, 5000) &&
             validStringLength('challenges', 0, 5000) &&
             validStringLength('intentions', 0, 5000) &&
             data.status in ['pending', 'completed'] &&
             data.uid == request.auth.uid;
    }

    function isValidTask(data) {
      let requiredFields = ['title', 'date', 'time', 'completed', 'priority', 'uid'];
      let optionalFields = ['recurrence', 'xpReward'];
      let allFields = requiredFields.concat(optionalFields);

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('title', 1, 200) &&
             validStringLength('date', 10, 10) &&
             validStringLength('time', 0, 10) &&
             data.completed is bool &&
             data.priority in ['low', 'medium', 'high'] &&
             (!( 'recurrence' in data ) || data.recurrence in ['none', 'daily', 'weekly', 'monthly']) &&
             isValidOptionalNumber('xpReward') &&
             data.uid == request.auth.uid;
    }

    function isValidLedgerEntry(data) {
      let requiredFields = ['date', 'amount', 'type', 'description', 'uid'];
      let optionalFields = ['category'];
      let allFields = requiredFields.concat(optionalFields);

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('date', 10, 10) &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             validStringLength('description', 1, 500) &&
             isValidOptionalString('category', 0, 100) &&
             data.uid == request.auth.uid;
    }

    function isValidNutritionLog(data) {
      let requiredFields = ['date', 'type', 'name', 'calories', 'uid'];
      let optionalFields = ['protein', 'carbs', 'fat', 'duration', 'muscleGroup', 'amount'];
      let allFields = requiredFields.concat(optionalFields);

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('date', 10, 10) &&
             data.type in ['food', 'exercise', 'water'] &&
             validStringLength('name', 1, 200) &&
             data.calories is number && data.calories >= 0 &&
             isValidOptionalNumber('protein') &&
             isValidOptionalNumber('carbs') &&
             isValidOptionalNumber('fat') &&
             isValidOptionalNumber('duration') &&
             (!( 'muscleGroup' in data ) || data.muscleGroup in ['chest', 'back', 'legs', 'arms', 'shoulders', 'core', 'cardio']) &&
             isValidOptionalNumber('amount') &&
             data.uid == request.auth.uid;
    }

    function isValidTacticalLog(data) {
      let requiredFields = ['date', 'game', 'focusArea', 'result', 'kills', 'deaths', 'uid'];
      let optionalFields = ['notes'];
      let allFields = requiredFields.concat(optionalFields);

      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             validStringLength('date', 10, 10) &&
             validStringLength('game', 1, 200) &&
             validStringLength('focusArea', 1, 200) &&
             data.result in ['win', 'loss', 'draw'] &&
             data.kills is number && data.kills >= 0 &&
             data.deaths is number && data.deaths >= 0 &&
             isValidOptionalString('notes', 0, 5000) &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /userStats/{uid} {
      allow read: if isOwner(uid) || (isAuthenticated() && request.auth.uid in resource.data.friends);
      allow create: if isOwner(uid) && isValidUserStats(request.resource.data) && uidUnchanged();
      allow update: if (isOwner(uid) && isValidUserStats(request.resource.data) && uidNotModified()) ||
                    (isAuthenticated() && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) &&
                     request.resource.data.friends.hasAll(resource.data.get('friends', [])) &&
                     request.resource.data.friends.size() == resource.data.get('friends', []).size() + 1 &&
                     request.auth.uid in request.resource.data.friends &&
                     !(request.auth.uid in resource.data.get('friends', [])) &&
                     isFriendRequestAccepted(request.auth.uid, uid));
      allow delete: if isOwner(uid);
    }

    match /publicProfiles/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidPublicProfile(request.resource.data) && uidUnchanged();
      allow update: if isOwner(uid) && isValidPublicProfile(request.resource.data) && uidNotModified();
      allow delete: if isOwner(uid);
    }

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.fromUid == request.auth.uid && isValidFriendRequest(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.toUid == request.auth.uid && request.resource.data.status in ['accepted', 'rejected'] && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        (resource.data.fromUid == request.auth.uid && request.resource.data.status == 'pending')
      ) && isValidFriendRequest(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    match /quests/{questId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidQuest(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidQuest(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /dungeons/{dungeonId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDungeon(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidDungeon(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /inventory/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidInventoryItem(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidInventoryItem(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /shopItems/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidShopItem(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidShopItem(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /vesselLogs/{logId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidVesselLog(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidVesselLog(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /weeklyReviews/{reviewId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidWeeklyReview(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidWeeklyReview(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidTask(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /ledger/{entryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidLedgerEntry(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidLedgerEntry(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /nutritionLogs/{logId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNutritionLog(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidNutritionLog(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /tacticalLogs/{logId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTacticalLog(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidTacticalLog(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
